{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/components/ui/**/*",
    "src/lib/utils.ts"
  ],
  "exclude": [
    "src/routes/**",
    "src/server.ts",
    "src/start.ts",
    "src/router.tsx",
    "src/hooks/**",
    "src/components/showcase-*"
  ]
}
